{
  "extends": "../../packages/tsconfig/base.json",
  "compilerOptions": {
    "outDir": "lib",
    "rootDir": "src",
    "incremental": true,
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "baseUrl": "./",
    "paths": {
      "koishi-plugin-chatluna/services/chat": ["node_modules/koishi-plugin-chatluna/lib/services/chat"],
      "koishi-plugin-chatluna/utils/string": ["node_modules/koishi-plugin-chatluna/lib/utils/string"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "lib", "dist", "client"]
}
