{
  "name": "koishi-plugin-chatluna-affinity",
  "description": "ChatLuna Character 好感度系统，提供 {好感度}、{关系}、{黑名单} 变量与工具，并支持 XML 工具调用，仅支持 onebot 平台。",
  "version": "0.3.8",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "dist"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsup && vite build",
    "watch": "tsup --watch",
    "clean": "rimraf lib dist",
    "typecheck": "yarn workspace shared-chatluna-xmltools build && tsc --noEmit",
    "test": "node --import tsx --test --test-name-pattern='.*' $(find tests -name '*.test.ts' -print)"
  },
  "keywords": [
    "chatbot",
    "koishi",
    "plugin"
  ],
  "homepage": "https://github.com/Sor85/AAAAACAT-chatluna-plugins",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sor85/AAAAACAT-chatluna-plugins.git"
  },
  "koishi": {
    "browser": true,
    "public": [
      "dist"
    ],
    "description": {
      "zh": "ChatLuna Character 好感度系统，提供好感度、关系、黑名单变量与控制台仪表盘"
    },
    "service": {
      "required": [
        "chatluna",
        "database"
      ],
      "optional": [
        "console",
        "chatluna_group_analysis",
        "chatluna_character"
      ]
    }
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-jp": "5.2.10",
    "@fontsource-variable/noto-sans-kr": "5.2.10",
    "@fontsource-variable/noto-sans-sc": "5.2.10",
    "@langchain/core": "^0.3.62",
    "@takumi-rs/core": "1.8.7",
    "@takumi-rs/helpers": "1.8.7",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "koishi": "^4.18.7",
    "koishi-plugin-chatluna": "*",
    "koishi-plugin-chatluna-character": "*",
    "@koishijs/plugin-console": "^5.30.0",
    "koishi-plugin-chatluna-group-analysis": "*"
  },
  "peerDependenciesMeta": {
    "koishi-plugin-chatluna-character": {
      "optional": true
    },
    "@koishijs/plugin-console": {
      "optional": true
    },
    "koishi-plugin-chatluna-group-analysis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "@koishijs/client": "^5.30.0",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.14",
    "@tabler/icons-react": "^3.44.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.10.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-is": "^19",
    "@vitejs/plugin-vue": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-is": "^19.2.7",
    "recharts": "^3.8.1",
    "rimraf": "^5.0.5",
    "sass": "^1.77.0",
    "shared-chatluna-xmltools": "workspace:*",
    "shared-nav": "workspace:*",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vue": "^3.5.21"
  }
}
