{
  "name": "koishi-plugin-chatluna-meme-generator",
  "version": "0.0.1",
  "description": "Koishi plugin for meme-generator-main backend",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "exports": {
    ".": "./lib/index.js",
    "./package.json": "./package.json"
  },
  "keywords": [
    "koishi",
    "meme",
    "chatluna"
  ],
  "license": "MIT",
  "peerDependencies": {
    "koishi": "^4.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "koishi": "^4.18.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "koishi": {
    "service": {
      "required": [
        "http"
      ],
      "optional": [
        "notifier"
      ]
    }
  }
}
